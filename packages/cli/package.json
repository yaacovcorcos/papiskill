{
  "name": "papiskill",
  "version": "0.1.0",
  "description": "CLI for searching, installing, downloading, validating, and authenticating PapiSkill packages.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://papiskill.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaacovcorcos/papiskill.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/yaacovcorcos/papiskill/issues"
  },
  "keywords": [
    "agent",
    "skills",
    "skill-md",
    "cli",
    "codex",
    "claude-code",
    "cursor"
  ],
  "bin": {
    "papiskill": "./dist/index.js"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@papiskill/skill-core": "0.1.0",
    "commander": "^14.0.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.26",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
